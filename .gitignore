__pycache__/
*.py[cod]
.pytest_cache/
.pytest-artifacts/
.test-artifacts/
.test_runs/
.agent_core/

# Runtime data generated by local executions.  Keep versioned seed and
# configuration assets, but do not commit checkpoints or derived indexes.
data/langgraph/checkpoints.sqlite
data/langgraph/rag/
data/langgraph/artifacts/
data/langgraph/evolution/
data/langgraph/*.sqlite
data/langgraph/*.sqlite3
data/langgraph/*.sqlite-shm
data/langgraph/*.sqlite-wal

# Project-local state and generated acceptance output stay outside source
# control.  They are recreated by project initialization and test commands.
knowledge/
memory/
evolved_skills/
workflows/evolved/
reports/*acceptance*
reports/agent_loop-*
data/*.npz
data/papers/
cli_manual/
git-metadata/
aerospace_agent/langgraph_agent/data/
webui/node_modules/
# Recovery copies belong to the source/test roots below and are not
# distributable package data.
/aerospace_agent/langgraph_agent/config/
/aerospace_agent/langgraph_agent/schemas/
/aerospace_agent/langgraph_agent/superpowers/
/aerospace_agent/langgraph_agent/tests/
